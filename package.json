{
  "name": "karyo-api",
  "version": "0.0.1",
  "description": "Intelligent workspace management designed to organize tasks, track progress, and boost team productivity.",
  "author": "Yasin Abbasi",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:create": "mikro-orm-esm migration:create",
    "db:up": "mikro-orm-esm migration:up",
    "db:down": "mikro-orm-esm migration:down",
    "db:list": "mikro-orm-esm migration:list",
    "db:check": "mikro-orm-esm migration:check",
    "db:fresh": "mikro-orm-esm migration:fresh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/lib-storage": "^3.995.0",
    "@mikro-orm/core": "^6.6.7",
    "@mikro-orm/migrations": "^6.6.7",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/postgresql": "^6.6.7",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@types/ms": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "ms": "^2.1.3",
    "nestjs-zod": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@mikro-orm/cli": "^6.6.7",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "mikro-orm": {
    "configPaths": [
      "./src/configs/mikro-orm.config.ts",
      "./dist/configs/mikro-orm.config.js"
    ]
  }
}
